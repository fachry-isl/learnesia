# Django Secret Key (keep your existing one)
SECRET_KEY='your-secret-key-here'

# Database - SUPABASE CONFIGURATION (IPv4 Pooler)
DEBUG=True
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=
DB_SCHEMA=
# Instructions:
# 1. Go to https://supabase.com and create a new project
# 2. In your project, go to Settings > Database
# 3. Find the "Connection String" section
# 4. Copy the connection details:
#    - DB_HOST: The host from the connection string (db.xxxxxxxxxxxxx.supabase.co)
#    - DB_PASSWORD: The password you set when creating the project
# 5. Replace the values above with your actual Supabase credentials

# Gemini (keep your existing key)
GEMINI_API_KEY=apikey

# Host IP where django is deployed
DJANGO_ALLOWED_HOSTS=ip1,ip2
# Whitelist Frontend IP
CORS_ALLOWED_ORIGINS=ip1,ip2

